# ==============================
# Google Cloud / Gemini ADC
# ==============================
# Path to your Google service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service_account.json

# ==============================
# OpenAI TTS
# ==============================
OPENAI_API_KEY=

# ==============================
# MiniMax TTS
# ==============================
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# ==============================
# App Config
# ==============================
# Allowed frontend origin (change port if needed)
FRONTEND_ORIGIN=http://localhost:3000
# Max requests per minute for scraper endpoints
SCRAPER_RATE_LIMIT=30
